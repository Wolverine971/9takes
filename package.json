{
	"name": "9takes",
	"version": "0.0.1",
	"packageManager": "pnpm@11.7.0",
	"scripts": {
		"dev": "node --max-http-header-size=65536 ./node_modules/vite/bin/vite.js dev",
		"build": "vite build && node scripts/check-build-budgets.mjs",
		"build:vercel": "pnpm run gen:personality-image-map && pnpm run gen:corpus-stats && pnpm run gen:sitemap && pnpm run gen:llms && pnpm run build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"test": "vitest --run",
		"all:install": "pnpm -w i --filter=\"*\"",
		"all:build": "pnpm -w exec nx run-many --target=build",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:budgets": "node scripts/check-build-budgets.mjs",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"test:unit": "vitest",
		"lint": "prettier --check . && eslint . && node scripts/lint-radius.js",
		"lint:radius": "node scripts/lint-radius.js",
		"format": "prettier --write .",
		"format:transcripts": "prettier --ignore-path /dev/null --write youtube-transcript-research youtube-transcripts-people",
		"clean": "rimraf .svelte-kit",
		"gen:sctx": "tsx scripts/generateStreamlinedProjectContext2.ts . -o docs/archives/sproject-context.json",
		"label-paths": "tsx scripts/labelFilePaths.ts",
		"gen:types": "node scripts/generate-types.js",
		"gen:personality-image-map": "node scripts/generate-personality-image-slug-map.js",
		"gen:sitemap": "node scripts/generate-sitemap.js",
		"gen:llms": "node scripts/generate-llms.js",
		"gen:famous-types": "node scripts/generate-famous-types.js",
		"gen:corpus-stats": "node scripts/generate-corpus-stats.js",
		"gen:instagram-plan": "node --import tsx scripts/build-instagram-posting-plan.ts",
		"gen:crosslinks": "node scripts/generate-crosslink-report.js",
		"gen:search-index": "node scripts/index-blogs-to-supabase.js --if-env",
		"gen:all": "node scripts/gen-all.js",
		"gen:all:full": "node scripts/gen-all.js --all",
		"index:blogs": "node scripts/index-blogs-to-supabase.js",
		"index:blogs:dry": "node scripts/index-blogs-to-supabase.js --dry-run",
		"index:blogs:force": "node scripts/index-blogs-to-supabase.js --force",
		"push:people": "node scripts/personBlogParser.js",
		"gen:chorus": "node scripts/generate-chorus.mjs",
		"gen:chorus:force": "node scripts/generate-chorus.mjs --force",
		"regen:takes": "node --import tsx scripts/regen-nine-takes.ts",
		"audit:people-seo": "node scripts/audit-people-seo.js",
		"supabase:normalize-personality-slugs": "node scripts/normalize-personality-slugs.js",
		"seo:normalize-internal-personality-links": "node scripts/normalize-internal-personality-links.js",
		"test:smoke": "playwright test"
	},
	"devDependencies": {
		"@babel/parser": "^7.27.4",
		"@babel/traverse": "^7.27.4",
		"@babel/types": "^7.27.3",
		"@eslint/js": "^8.57.1",
		"@playwright/test": "^1.61.1",
		"@sveltejs/adapter-vercel": "^6.3.4",
		"@sveltejs/enhanced-img": "^0.9.2",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.20",
		"@testing-library/svelte": "^5.4.2",
		"@types/d3": "^7.4.3",
		"@types/gtag.js": "^0.0.20",
		"@types/pluralize": "^0.0.33",
		"@types/qrcode": "^1.5.6",
		"@typescript-eslint/eslint-plugin": "^6.21.0",
		"@typescript-eslint/parser": "^6.21.0",
		"autoprefixer": "^10.5.3",
		"eslint": "^8.57.1",
		"eslint-config-prettier": "^8.10.0",
		"eslint-plugin-svelte": "^3.20.0",
		"fast-glob": "^3.3.3",
		"flowbite": "^2.5.1",
		"jsdom": "^29.1.1",
		"mdsvex": "^0.12.7",
		"postcss": "^8.5.19",
		"postcss-load-config": "^4.0.2",
		"postcss-preset-env": "^7.8.3",
		"postcss-simple-vars": "^7.0.1",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"sass": "^1.101.0",
		"supabase": "^1.192.5",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.2",
		"svelte-eslint-parser": "^1.8.0",
		"svelte-preprocess": "^6.0.5",
		"tailwindcss": "^3.4.9",
		"tslib": "^2.7.0",
		"tsx": "^4.23.1",
		"typescript": "^5.9.2",
		"vite": "^7.3.5",
		"vitest": "^4.1.10"
	},
	"browser": {
		"crypto": false
	},
	"type": "module",
	"engines": {
		"node": ">=22.12.0",
		"pnpm": ">=11.7.0 <12"
	},
	"dependencies": {
		"@chenglou/pretext": "^0.0.8",
		"@elastic/elasticsearch": "^8.15.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource/jetbrains-mono": "^5.2.8",
		"@lucide/svelte": "1.24.0",
		"@supabase/ssr": "^0.12.3",
		"@supabase/supabase-js": "^2.110.5",
		"axios": "^1.18.1",
		"cheerio": "^1.2.0",
		"d3": "^7.9.0",
		"d3-cloud": "^1.2.9",
		"dotenv": "^16.4.5",
		"googleapis": "^173.0.0",
		"gray-matter": "^4.0.3",
		"html-to-image": "^1.11.11",
		"html2canvas": "^1.4.1",
		"jspdf": "^4.2.1",
		"marked": "^16.2.0",
		"opentype.js": "^1.3.4",
		"pluralize": "^8.0.0",
		"postcss-scss": "^4.0.9",
		"posthog-js": "^1.400.0",
		"qrcode": "^1.5.4",
		"rehype-slug": "^5.1.0",
		"remark-abbr": "^1.4.2",
		"remark-github": "^11.2.4",
		"sharp": "^0.34.5",
		"stemmer": "^2.0.1",
		"stripe": "^11.18.0",
		"uuid": "^11.1.1",
		"web-vitals": "^3.5.2",
		"zod": "^3.25.76"
	}
}
