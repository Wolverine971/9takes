{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"version": 2,
	"alias": "9takes.com",
	"framework": "sveltekit",
	"installCommand": "pnpm i --frozen-lockfile",
	"buildCommand": "pnpm run build:vercel",
	"headers": [
		{
			"source": "/fonts/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=31536000, immutable"
				}
			]
		},
		{
			"source": "/blogs/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		},
		{
			"source": "/books/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		},
		{
			"source": "/brand/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		},
		{
			"source": "/icons/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		},
		{
			"source": "/types/:path*",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "public, max-age=86400, stale-while-revalidate=604800"
				}
			]
		}
	],
	"crons": [
		{
			"path": "/api/cron/process-sequences",
			"schedule": "*/15 * * * *"
		},
		{
			"path": "/api/cron/tag-chorus-questions",
			"schedule": "*/15 * * * *"
		}
	],
	"redirects": [
		{
			"source": "/books/48-laws-of-power.PNG",
			"destination": "/books/48-laws-of-power.webp",
			"permanent": true
		},
		{
			"source": "/books/michelle-book-becoming.PNG",
			"destination": "/books/michelle-book-becoming.webp",
			"permanent": true
		},
		{
			"source": "/books/spare.PNG",
			"destination": "/books/spare.webp",
			"permanent": true
		},
		{
			"source": "/brand/dj-profile-pic.jpg",
			"destination": "/brand/dj-profile-pic.webp",
			"permanent": true
		},
		{
			"source": "/9takes-preview.svg",
			"destination": "/9takes-preview.png",
			"permanent": true
		},
		{
			"source": "/blog/famous-enneagram-types/type/:slug",
			"destination": "/personality-analysis/type/:slug",
			"permanent": true
		},
		{
			"source": "/blog/famous-enneagram-types/type",
			"destination": "/personality-analysis/type",
			"permanent": true
		},
		{
			"source": "/blog/famous-enneagram-types/:slug",
			"destination": "/personality-analysis/:slug",
			"permanent": true
		},
		{
			"source": "/blog/famous-enneagram-types",
			"destination": "/personality-analysis",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-precomposed.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-120x120.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-120x120-precomposed.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-152x152.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/apple-touch-icon-152x152-precomposed.png",
			"destination": "/brand/apple-touch-icon.png",
			"permanent": true
		},
		{
			"source": "/types/6s/David-Goggins.webp",
			"destination": "/types/8s/David-Goggins.webp",
			"permanent": true
		},
		{
			"source": "/sitemap_index.xml",
			"destination": "/sitemap.xml",
			"permanent": true
		},
		{
			"source": "/sitemap-index.xml",
			"destination": "/sitemap.xml",
			"permanent": true
		},
		{
			"source": "/sitemap.html",
			"destination": "/sitemap.xml",
			"permanent": true
		},
		{
			"source": "/sitemap.txt",
			"destination": "/sitemap.xml",
			"permanent": true
		}
	],
	"rewrites": [
		{
			"source": "/proxytown/gtm",
			"destination": "https://www.googletagmanager.com/gtag/js"
		},
		{
			"source": "/proxytown/ga",
			"destination": "https://www.google-analytics.com/analytics.js"
		}
	]
}
